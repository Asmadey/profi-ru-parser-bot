# Specialties configuration for the Profi.ru Parser Bot
#
# This file defines multiple specialties that the bot can match against
# incoming orders. Each specialty is a set of filter rules:
#
#   name                 : Human-readable identifier (required)
#   target_keywords      : List of regex strings — order must match at least one
#   dev_keywords         : List of plain strings — order must contain at least one
#   disallowed_topics    : List of plain strings — order is rejected if any found
#   disallowed_platforms : List of regex strings — order is rejected if any found
#   budget_min           : Minimum budget in rubles (default: 10000)
#   chat_id              : Telegram chat ID for routing (null = default chat)
#
# If this file is missing or empty, the bot falls back to DEFAULT_SPECIALTY
# (the original hardcoded patterns from filters.py).
#
# Copy this file to specialties.yaml and customise as needed.

# ---------------------------------------------------------------------------
# Specialty 1: AI/ML — same keywords as the original hardcoded default
# ---------------------------------------------------------------------------
- name: "AI/ML"
  target_keywords:
    # Bot / чат-бот
    - "(?iu)\\bбот\\b"
    - "(?iu)\\bбота\\b"
    - "(?iu)\\bботы\\b"
    - "(?iu)\\bботов\\b"
    - "(?iu)\\bботом\\b"
    - "(?iu)\\bботу\\b"
    - "(?iu)\\bчат[- ]?бот\\b"
    - "(?iu)\\bчат[- ]?бота\\b"
    - "(?iu)\\bchat[- ]?bot\\b"
    - "(?iu)\\bbot\\b"
    - "(?iu)\\bbots\\b"
    # CRM
    - "(?iu)\\bcrm\\b"
    - "(?iu)\\bcrm[- ]?систем\\w*\\b"
    - "(?iu)\\bцрм\\b"
    - "(?iu)\\bцрм[- ]?систем\\w*\\b"
    - "(?iu)\\bсрм\\b"
    - "(?iu)\\bсрм[- ]?систем\\w*\\b"
    - "(?iu)\\bси[- ]?ар[- ]?эм\\b"
    # Parser / парсинг
    - "(?iu)\\bпарсер\\w*\\b"
    - "(?iu)\\bпарсинг\\w*\\b"
    - "(?iu)\\bпарсить\\b"
    - "(?iu)\\bпарсить\\w*\\b"
    - "(?iu)\\bспарс\\w*\\b"
    - "(?iu)\\bраспарс\\w*\\b"
    - "(?iu)\\bparser\\w*\\b"
    - "(?iu)\\bparsing\\b"
    - "(?iu)\\bparse\\b"
    # Automation / автоматизация
    - "(?iu)\\bавтоматизац\\w*\\b"
    - "(?iu)\\bавтоматизир\\w*\\b"
    - "(?iu)\\bавтоматическ\\w*\\b"
    - "(?iu)\\bautomation\\b"
    - "(?iu)\\bautomate\\b"
    - "(?iu)\\bautomated\\b"
  dev_keywords:
    - разработка
    - разработать
    - разработчик
    - создать
    - создание
    - сделать
    - написать
    - реализовать
    - доработать
    - настроить
    - настройка
    - внедрить
    - внедрение
    - интегрировать
    - интеграция
    - нужен
    - нужна
    - нужно
    - нужны
    - требуется
    - требуются
    - необходимо
    - надо
    - ищу
    - заказать
    - хочу
  disallowed_topics:
    - таргет
    - таргетинг
    - таргетированная реклама
    - контекстная реклама
    - директ
    - smm
    - смм
    - продвижение
    - рекламная кампания
    - специалист по рекламе
    - настройка рекламы
    - ведение рекламы
  disallowed_platforms:
    - "(?iu)\\binstagram\\b"
    - "(?iu)\\bинстаграм\\b"
    - "(?iu)\\binsta\\b"
    - "(?iu)\\bwhatsapp\\b"
    - "(?iu)\\bватсап\\b"
    - "(?iu)\\bfacebook\\b"
    - "(?iu)\\bdiscord\\b"
  budget_min: 10000
  chat_id: null  # route to default chat

